generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id                  String          @id @default(cuid())
  titleAr             String
  slug                String          @unique
  shortDescAr         String
  contentAr           String
  seoTitleAr          String?
  seoDescriptionAr    String?
  imageUrl            String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  coverImage          String?
  gallery             String[]        @default([])
  isPublished         Boolean         @default(true)
  videoUrl            String?
  galleryDescriptions String[]        @default([])
  sortOrder           Int             @default(0)
  seoPage             ServiceSeoPage?
}

model ServiceSeoPage {
  id              String   @id @default(cuid())
  serviceId       String   @unique
  title           String
  slug            String   @unique
  metaTitle       String?
  metaDescription String?
  contentSections Json
  images          String[] @default([])
  faq             Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Project {
  id               String   @id @default(cuid())
  titleAr          String
  slug             String   @unique
  locationAr       String
  categoryAr       String
  descriptionAr    String
  beforeImage      String?
  afterImage       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  coverImage       String?
  gallery          String[] @default([])
  isPublished      Boolean  @default(true)
  seoDescriptionAr String?
  seoTitleAr       String?
  videoUrl         String?
}

model BlogPost {
  id               String   @id @default(cuid())
  titleAr          String
  slug             String   @unique
  excerptAr        String
  contentAr        String
  seoTitleAr       String?
  seoDescriptionAr String?
  coverImage       String?
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Lead {
  id          String     @id @default(cuid())
  fullName    String
  phone       String
  whatsapp    String?
  city        String
  serviceType String
  message     String?
  imageUrl    String?
  status      LeadStatus @default(NEW)
  source      String     @default("website")
  crmNotes    String?
  pageUrl     String?
  userAgent   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  locationUrl String?
}

model Setting {
  id             String   @id @default(cuid())
  siteNameAr     String
  siteDescAr     String
  primaryPhone   String
  whatsappNumber String
  addressAr      String
  lat            Float?
  lng            Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ClickEvent {
  id        String   @id @default(cuid())
  type      String
  pageUrl   String?
  createdAt DateTime @default(now())
}

enum UserRole {
  OWNER
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}
